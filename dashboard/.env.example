# Bot Command Center — optional config. Copy to dashboard/.env (gitignored).

# ── Persistence (uptime history survives restarts) ──────────────────────────
CC_DB_PATH=data/command_center.db     # relative paths resolve under dashboard/
CC_RETENTION_DAYS=7                    # prune samples older than this on startup

# ── Server ──────────────────────────────────────────────────────────────────
CC_HOST=127.0.0.1
CC_PORT=8000
CC_REFRESH_SECONDS=15                  # cadence the UI counts down to

# ── Telegram alerts on status changes (optional; blank = disabled) ──────────
# Make a bot with @BotFather for the token; get your chat id from @userinfobot.
CC_TELEGRAM_BOT_TOKEN=
CC_TELEGRAM_CHAT_ID=
